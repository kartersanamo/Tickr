# Tickr Web Dashboard — copy to .env.dashboard and fill in values.
# Can share DB_* and DISCORD_BOT_TOKEN with the main bot .env.

# --- Next.js / Auth.js ---
AUTH_SECRET=                        # openssl rand -base64 32
AUTH_URL=https://tickr.kartersanamo.com
NEXTAUTH_URL=https://tickr.kartersanamo.com
NEXTAUTH_SECRET=                    # same as AUTH_SECRET

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
NEXT_PUBLIC_DISCORD_CLIENT_ID=      # same as DISCORD_CLIENT_ID
NEXT_PUBLIC_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=CLIENT_ID&permissions=268823744&scope=bot%20applications.commands
NEXT_PUBLIC_SITE_URL=https://tickr.kartersanamo.com

# Shared secret between web proxy and FastAPI (openssl rand -base64 32)
DASHBOARD_INTERNAL_SECRET=

# Web → API (docker-compose sets this for tickr-web container)
TICKR_API_URL=http://127.0.0.1:8790

# --- FastAPI / MySQL ---
# Use 127.0.0.1 when the API runs on the host. Docker Compose overrides DB_HOST to
# host.docker.internal for tickr-api so it can reach MySQL on the host machine.
DISCORD_BOT_TOKEN=                  # same as DISCORD_TOKEN in bot .env
DISCORD_TOKEN=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=tickr
DB_AUTOCOMMIT=true

TICKETS_BOT_API_URL=http://host.docker.internal:8788
# Shared with the Discord bot (.env) — used for live ticket notifications
TICKETS_BOT_API_SECRET=
TICKETS_BOT_API_PORT=8788

CORS_ORIGINS=https://tickr.kartersanamo.com,http://localhost:3000
