# Discord Bot Token
DISCORD_TOKEN=

# Optional: dev guild for instant slash-command sync (production uses global sync)
DISCORD_GUILD_ID=

# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_AUTOCOMMIT=true

# Bot branding
BOT_PRESENCE=Tickr Tickets

# Transcript paste service (global default; per-guild override in guild config)
TRANSCRIPT_PASTE_URL=
TRANSCRIPT_PASTE_SUFFIX=/documents

# Optional dashboard integration
DASHBOARD_URL=
DASHBOARD_TICKET_NOTIFY_URL=
TICKETS_BOT_API_SECRET=
TICKETS_BOT_API_PORT=8788

# Optional per-guild default if not set in guild config
TICKET_BLACKLIST_WEBHOOK=
